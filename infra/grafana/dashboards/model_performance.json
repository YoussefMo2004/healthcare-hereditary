{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "ML model performance monitoring — risk score distribution, drift metrics, and production Brier/AUC trends",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Prediction Risk Score — Median (p50) over time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(healthcare_prediction_risk_score_bucket[30m])) by (le))",
          "legendFormat": "p50 score", "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.90, sum(rate(healthcare_prediction_risk_score_bucket[30m])) by (le))",
          "legendFormat": "p90 score", "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 0.75 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Risk Tier Distribution (predictions/min)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Derived from score histogram buckets: low (<0.25), moderate (0.25–0.5), high (0.5–0.75), very_high (>0.75)",
      "targets": [
        {
          "expr": "sum(rate(healthcare_prediction_risk_score_bucket{le=\"0.25\"}[5m]))",
          "legendFormat": "low (<0.25)", "refId": "A"
        },
        {
          "expr": "sum(rate(healthcare_prediction_risk_score_bucket{le=\"0.5\"}[5m])) - sum(rate(healthcare_prediction_risk_score_bucket{le=\"0.25\"}[5m]))",
          "legendFormat": "moderate (0.25–0.5)", "refId": "B"
        },
        {
          "expr": "sum(rate(healthcare_prediction_risk_score_bucket{le=\"0.75\"}[5m])) - sum(rate(healthcare_prediction_risk_score_bucket{le=\"0.5\"}[5m]))",
          "legendFormat": "high (0.5–0.75)", "refId": "C"
        },
        {
          "expr": "sum(rate(healthcare_prediction_risk_score_bucket{le=\"+Inf\"}[5m])) - sum(rate(healthcare_prediction_risk_score_bucket{le=\"0.75\"}[5m]))",
          "legendFormat": "very_high (>0.75)", "refId": "D"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 3,
      "title": "Cache Hit Rate — Hereditary Risk",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 * sum(rate(healthcare_cache_operations_total{result=\"hit\"}[5m])) / sum(rate(healthcare_cache_operations_total[5m]))",
          "legendFormat": "hit rate %", "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 80 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Prediction Throughput (req/min)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "60 * sum(rate(healthcare_http_requests_total{path=\"/predict/hereditary-risk\", status=\"200\"}[5m]))",
          "legendFormat": "predictions/min", "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 1 } }
    },
    {
      "id": 5,
      "title": "Model Not Loaded Alert",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "healthcare_model_loaded", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "MODEL DOWN", "color": "red" }, "1": { "text": "MODEL OK", "color": "green" } }, "type": "value" }
          ]
        }
      }
    }
  ],
  "refresh": "1m",
  "schemaVersion": 38,
  "tags": ["healthcare", "ml", "model"],
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Model Performance",
  "uid": "healthcare-model-perf",
  "version": 1
}
