{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Healthcare Prediction API — request rates, latency, error rates, and rate limiting",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(healthcare_http_requests_total[5m])) by (path)",
          "legendFormat": "{{ path }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 2,
      "title": "Error Rate (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 * sum(rate(healthcare_http_requests_total{status=~\"5..\"}[5m])) / sum(rate(healthcare_http_requests_total[5m]))",
          "legendFormat": "5xx %",
          "refId": "A"
        },
        {
          "expr": "100 * sum(rate(healthcare_http_requests_total{status=~\"4..\"}[5m])) / sum(rate(healthcare_http_requests_total[5m]))",
          "legendFormat": "4xx %",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Latency Percentiles — /predict/hereditary-risk",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(healthcare_http_request_duration_seconds_bucket{path=\"/predict/hereditary-risk\"}[5m])) by (le))",
          "legendFormat": "p50", "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(healthcare_http_request_duration_seconds_bucket{path=\"/predict/hereditary-risk\"}[5m])) by (le))",
          "legendFormat": "p95", "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(healthcare_http_request_duration_seconds_bucket{path=\"/predict/hereditary-risk\"}[5m])) by (le))",
          "legendFormat": "p99", "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 4,
      "title": "Rate Limit Rejections (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(healthcare_rate_limit_rejected_total[5m])) by (path)",
          "legendFormat": "{{ path }}", "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 5,
      "title": "Model Loaded",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "healthcare_model_loaded", "legendFormat": "Model Loaded", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      }
    },
    {
      "id": 6,
      "title": "Prediction Score Distribution",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 20, "x": 4, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(healthcare_prediction_risk_score_bucket[1h])) by (le)",
          "legendFormat": "{{ le }}", "refId": "A", "format": "heatmap"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["healthcare", "api"],
  "templating": { "list": [] },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Healthcare API Overview",
  "uid": "healthcare-api-overview",
  "version": 1
}
